{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Vss": "Server=.\\SQLEXPRESS;Database=Vss;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Frontend": {
    "Origin": "http://localhost:5173"
  },

  "Auth": {
    "Mode": "Dev"
  },

  "// AzureAd": "Set Auth:Mode=Entra and fill these on the Univerus network.",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<your-entra-tenant-id>",
    "ClientId": "<vss-api-app-registration-client-id>",
    "Audience": "api://<vss-api-app-registration-client-id>"
  },

  "// Erp": "Provider = Stub | SapByDesign | BusinessCentral. Secrets go in user-secrets/env, NOT here (Erp__BusinessCentral__ClientSecret, Erp__SapByDesign__Password).",
  "Erp": {
    "Provider": "Stub",
    "BusinessCentral": {
      "BaseUrl": "https://api.businesscentral.dynamics.com/v2.0/<tenantId>/<environment>/api/v2.0",
      "CompanyId": "<company-guid>",
      "TenantId": "<entra-tenant-id>",
      "ClientId": "<app-registration-client-id>",
      "Scope": "https://api.businesscentral.dynamics.com/.default",
      "SampleVendorNumber": ""
    },
    "SapByDesign": {
      "BaseUrl": "https://myXXXXXX.sapbydesign.com",
      "QuerySupplierPath": "/sap/bc/srt/scs/sap/querysupplierin",
      "ManageSupplierPath": "/sap/bc/srt/scs/sap/managesupplierin",
      "Username": "<communication-arrangement-user>",
      "SampleSupplierId": ""
    }
  }
}
